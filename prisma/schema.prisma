datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Invoice {
  id           String     @id @default(uuid()) @db.Uuid
  customer     String     @db.VarChar(255)
  bill_no      String     @unique @db.VarChar(100)
  value        Decimal    @db.Decimal(12, 2)
  tax          Decimal    @db.Decimal(12, 2)
  total        Decimal    @db.Decimal(12, 2)
  status       String     @default("draft") @db.VarChar(20)
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  updated_at   DateTime   @updatedAt @db.Timestamptz(6)
  pdf_file     PdfFile?
  ocr_result   OcrResult?

  @@map("invoices_invoice") // Maps directly to Django's auto-generated app table name
}

model PdfFile {
  id             String   @id @default(uuid()) @db.Uuid
  invoice_id     String   @unique @db.Uuid
  invoice        Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  filename       String   @db.VarChar(255)
  cloudinary_url String   @db.VarChar(500)
  public_id      String   @db.VarChar(255)
  size_bytes     Int
  uploaded_at    DateTime @default(now()) @db.Timestamptz(6)

  @@map("invoices_pdffile")
}

model OcrResult {
  id             String   @id @default(uuid()) @db.Uuid
  invoice_id     String   @unique @db.Uuid
  invoice        Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  raw_text       String   @db.Text
  confidence     Float
  bounding_boxes Json     // Stored cleanly as JSONB
  processed_at   DateTime @default(now()) @db.Timestamptz(6)

  @@map("invoices_ocrresult")
}