# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js build dumps
/.next/
/out/

# production output build targets
/build
dist/
*.sh.local

# misc caches
.DS_Store
*.pem
.logs/
*.log

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
