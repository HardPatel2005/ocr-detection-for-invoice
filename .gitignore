.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel deployments cache tracking
.vercel

# typescript incremental compilation traces
*.tsbuildinfo
next-env.d.ts

# prisma generated model engine definitions
/app/generated/prisma
/src/generated/client

# python build and cache output footprints
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv
venv/
ENV/